<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>room musik horeki</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800;900&display=swap" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #0a0a1a;
            background-image:
                radial-gradient(ellipse at 10% 30%, rgba(120, 0, 255, 0.30) 0%, transparent 55%),
                radial-gradient(ellipse at 90% 70%, rgba(255, 0, 150, 0.25) 0%, transparent 55%),
                radial-gradient(ellipse at 50% 100%, rgba(0, 200, 255, 0.12) 0%, transparent 45%),
                linear-gradient(145deg, #0a0a1a 0%, #15082a 100%);
            background-attachment: fixed;
            padding: 16px;
        }
        .music-card {
            max-width: 500px;
            width: 100%;
            background: rgba(16, 8, 32, 0.70);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-radius: 44px;
            padding: 28px 22px 30px;
            border: 1px solid rgba(255, 255, 255, 0.06);
            box-shadow: 0 40px 100px rgba(0, 0, 0, 0.85), 0 0 0 1px rgba(255, 255, 255, 0.02) inset;
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
        }
        .music-card::before {
            content: '';
            position: absolute;
            top: -60%;
            left: -60%;
            width: 220%;
            height: 220%;
            background: conic-gradient(from 0deg at 50% 50%,
                    rgba(130, 0, 255, 0.07),
                    rgba(0, 200, 255, 0.04),
                    rgba(255, 0, 150, 0.07),
                    rgba(130, 0, 255, 0.07));
            animation: spinGlow 25s linear infinite;
            z-index: 0;
            pointer-events: none;
        }
        @keyframes spinGlow {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        .music-card>* {
            position: relative;
            z-index: 1;
        }
        .header {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .profile-img {
            width: 68px;
            height: 68px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255, 255, 255, 0.10);
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5);
            flex-shrink: 0;
            background: #15082a;
        }
        .header-info {
            flex: 1;
            min-width: 0;
        }
        .header-info .web-name {
            font-size: 22px;
            font-weight: 800;
            color: #fff;
            line-height: 1.2;
            letter-spacing: 0.3px;
        }
        .header-info .web-name span {
            background: linear-gradient(135deg, #a855f7, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .header-info .sub {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.40);
            font-weight: 300;
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }
        .header-info .sub i {
            color: #a855f7;
            font-size: 11px;
        }
        .header-info .beta-badge {
            display: inline-block;
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            background: rgba(168, 85, 247, 0.20);
            color: #c084fc;
            padding: 2px 10px;
            border-radius: 30px;
            border: 1px solid rgba(168, 85, 247, 0.15);
            margin-left: 4px;
        }
        .now-playing {
            display: flex;
            align-items: center;
            gap: 14px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 18px;
            padding: 10px 14px;
            margin-bottom: 20px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(4px);
        }
        .now-playing .artwork {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            object-fit: cover;
            background: #15082a;
            border: 1px solid rgba(255, 255, 255, 0.06);
            flex-shrink: 0;
        }
        .now-playing .np-info {
            flex: 1;
            min-width: 0;
        }
        .now-playing .np-info .np-title {
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .now-playing .np-info .np-artist {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.35);
            font-weight: 300;
        }
        .now-playing .np-status {
            font-size: 12px;
            color: #a855f7;
            font-weight: 400;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-shrink: 0;
        }
        .now-playing .np-status i {
            font-size: 9px;
            animation: pulseDot 1.6s ease-in-out infinite;
        }
        @keyframes pulseDot {
            0%, 100% { opacity: 0.25; transform: scale(0.8); }
            50% { opacity: 1; transform: scale(1.2); }
        }
        .player-controls {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 16px;
            margin-bottom: 18px;
            padding: 4px 0;
        }
        .player-controls button {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.50);
            font-size: 22px;
            cursor: pointer;
            transition: all 0.25s ease;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255, 255, 255, 0.04);
        }
        .player-controls button:hover {
            color: #fff;
            background: rgba(168, 85, 247, 0.12);
            border-color: rgba(168, 85, 247, 0.15);
            transform: scale(1.04);
        }
        .player-controls .btn-play {
            width: 64px;
            height: 64px;
            font-size: 28px;
            background: linear-gradient(135deg, #a855f7, #ec4899);
            color: #fff;
            border: none;
            box-shadow: 0 8px 36px rgba(168, 85, 247, 0.30);
        }
        .player-controls .btn-play:hover {
            transform: scale(1.06);
            box-shadow: 0 12px 48px rgba(168, 85, 247, 0.45);
            background: linear-gradient(135deg, #b96aff, #f05aae);
        }
        .player-controls .btn-play i {
            margin-left: 3px;
        }
        .progress-wrap {
            margin-bottom: 20px;
        }
        .progress-bar {
            width: 100%;
            height: 5px;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.07);
            cursor: pointer;
            position: relative;
            transition: height 0.2s;
        }
        .progress-bar:hover {
            height: 7px;
        }
        .progress-bar .progress-fill {
            height: 100%;
            width: 0%;
            border-radius: 10px;
            background: linear-gradient(90deg, #a855f7, #ec4899);
            transition: width 0.08s linear;
            position: relative;
        }
        .progress-bar .progress-fill::after {
            content: '';
            position: absolute;
            right: -5px;
            top: -4px;
            width: 13px;
            height: 13px;
            background: #fff;
            border-radius: 50%;
            box-shadow: 0 0 24px rgba(168, 85, 247, 0.5);
            opacity: 0;
            transition: opacity 0.2s;
        }
        .progress-bar:hover .progress-fill::after {
            opacity: 1;
        }
        .time-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.30);
            margin-top: 5px;
            font-weight: 300;
            letter-spacing: 0.2px;
        }
        .playlist {
            margin-top: 4px;
        }
        .playlist-title {
            font-size: 13px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.40);
            letter-spacing: 1px;
            text-transform: uppercase;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .playlist-title i {
            font-size: 12px;
            color: #a855f7;
        }
        .playlist-title .count {
            font-weight: 300;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.20);
            margin-left: auto;
        }
        .playlist-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 14px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.03);
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.25s ease;
        }
        .playlist-item:hover {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(168, 85, 247, 0.12);
            transform: translateX(4px);
        }
        .playlist-item.active {
            background: rgba(168, 85, 247, 0.08);
            border-color: rgba(168, 85, 247, 0.20);
            box-shadow: 0 0 30px rgba(168, 85, 247, 0.04);
        }
        .playlist-item .pl-index {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.04);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 600;
            color: rgba(255, 255, 255, 0.25);
            flex-shrink: 0;
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: all 0.3s;
        }
        .playlist-item.active .pl-index {
            background: linear-gradient(135deg, #a855f7, #ec4899);
            color: #fff;
            border-color: transparent;
        }
        .playlist-item .pl-info {
            flex: 1;
            min-width: 0;
        }
        .playlist-item .pl-info .pl-title {
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .playlist-item .pl-info .pl-artist {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.28);
            font-weight: 300;
        }
        .playlist-item .pl-play {
            color: rgba(255, 255, 255, 0.15);
            font-size: 16px;
            transition: all 0.2s;
            width: 28px;
            text-align: center;
            flex-shrink: 0;
        }
        .playlist-item.active .pl-play {
            color: #a855f7;
        }
        .playlist-item:hover .pl-play {
            color: rgba(255, 255, 255, 0.50);
        }
        .playlist-item.active:hover .pl-play {
            color: #ec4899;
        }
        .playlist-item .pl-dur {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.18);
            font-weight: 300;
            flex-shrink: 0;
            min-width: 36px;
            text-align: right;
        }
        .footer {
            margin-top: 22px;
            padding-top: 16px;
            border-top: 1px solid rgba(255, 255, 255, 0.04);
        }
        .footer-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }
        .footer .info-version {
            font-size: 11px;
            color: rgba(255, 255, 255, 0.25);
            font-weight: 300;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .footer .info-version i {
            color: #a855f7;
            font-size: 12px;
        }
        .footer .info-version .version {
            font-weight: 600;
            color: rgba(255, 255, 255, 0.35);
        }
        .btn-contact {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 9px 20px;
            border-radius: 40px;
            background: linear-gradient(135deg, #25D366, #128C7E);
            color: #fff;
            font-weight: 600;
            font-size: 13px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 6px 24px rgba(37, 211, 102, 0.20);
            font-family: 'Poppins', sans-serif;
        }
        .btn-contact:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 10px 36px rgba(37, 211, 102, 0.35);
        }
        .btn-contact i {
            font-size: 16px;
        }
        .footer .credit {
            text-align: center;
            font-size: 10px;
            color: rgba(255, 255, 255, 0.12);
            margin-top: 12px;
            letter-spacing: 0.5px;
        }
        @media (max-width: 480px) {
            .music-card {
                padding: 20px 14px 22px;
                border-radius: 32px;
            }
            .header-info .web-name {
                font-size: 18px;
            }
            .profile-img {
                width: 54px;
                height: 54px;
            }
            .player-controls .btn-play {
                width: 56px;
                height: 56px;
                font-size: 24px;
            }
            .player-controls button {
                width: 42px;
                height: 42px;
                font-size: 18px;
            }
            .playlist-item {
                padding: 8px 10px;
            }
            .playlist-item .pl-title {
                font-size: 13px;
            }
            .footer-top {
                flex-direction: column;
                align-items: stretch;
            }
            .btn-contact {
                justify-content: center;
            }
            .now-playing .artwork {
                width: 44px;
                height: 44px;
            }
            .now-playing .np-info .np-title {
                font-size: 13px;
            }
        }
        ::-webkit-scrollbar {
            width: 3px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(168, 85, 247, 0.25);
            border-radius: 10px;
        }
    </style>
</head>
