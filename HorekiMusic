    <audio id="audioPlayer" preload="metadata"></audio>

    <script>
        (function() {
            'use strict';
            const audio = document.getElementById('audioPlayer');
            const playBtn = document.getElementById('playBtn');
            const playIcon = document.getElementById('playIcon');
            const progressFill = document.getElementById('progressFill');
            const progressBar = document.getElementById('progressBar');
            const currentTimeLabel = document.getElementById('currentTime');
            const totalTimeLabel = document.getElementById('totalTime');
            const npTitle = document.getElementById('npTitle');
            const npArtist = document.getElementById('npArtist');
            const statusText = document.getElementById('statusText');
            const items = document.querySelectorAll('.playlist-item');
            const durElements = {
                0: document.getElementById('dur0'),
                1: document.getElementById('dur1'),
                2: document.getElementById('dur2'),
                3: document.getElementById('dur3'),
                4: document.getElementById('dur4'),
                5: document.getElementById('dur5'),
                6: document.getElementById('dur6'),
                7: document.getElementById('dur7'),
                8: document.getElementById('dur8'),
                9: document.getElementById('dur9'),
                10: document.getElementById('dur10'),
                11: document.getElementById('dur11'),
                12: document.getElementById('dur12'),
                13: document.getElementById('dur13'),
                14: document.getElementById('dur14'),
                15: document.getElementById('dur15'),
                16: document.getElementById('dur16'),
            };

            const tracks = [
                { url: 'https://x.xcute.workers.dev/f/audios/3bd7f7b9c2a9.mp3', title: 'DJ BANG DIKA', artist: 'horeki' },
                { url: 'https://x.xcute.workers.dev/f/audios/5057a08ea032.mp3', title: 'DALINDA X DORA DORA', artist: 'horeki' },
                { url: 'https://x.xcute.workers.dev/f/audios/c79a9ea3b5c7.mp3', title: 'DJ DONGHUA X DANCING JODI', artist: 'horeki' },
                { url: 'https://x.xcute.workers.dev/f/audios/ddb6bc9b5faa.mp3', title: 'DJ TERENA METE', artist: 'horeki' },
                { url: 'https://x.xcute.workers.dev/f/audios/cac02c9a2bef.mp3', title: 'DJ BACABU OLD', artist: 'horeki' },
                { url: 'https://c.termai.cc/a180/MOuQArK.mp3', title: 'DJ BLOODLINE MENGKANE', artist: 'horeki' },
                { url: 'https://c.termai.cc/a165/VISggB.mp3', title: 'DJ Bintang 5', artist: 'horeki' },
                { url: 'https://c.termai.cc/a187/dhPhBj.mp3', title: 'DJ Pacarku Memang Dekat', artist: 'horeki' },
                { url: 'https://c.termai.cc/a190/sDLKSnX.mp3', title: 'Reckless', artist: 'horeki' },
                { url: 'https://c.termai.cc/a140/c9PWi.mp3', title: 'Last Child - Bernapas Tanpamu', artist: 'horeki' },
                { url: 'https://c.termai.cc/a168/7HzPB.mp3', title: 'Last Child - Pedih', artist: 'horeki' },
                { url: 'https://c.termai.cc/a143/Tnnf.mp3', title: 'Last Child - Diary Depresi', artist: 'horeki' },
                { url: 'https://c.termai.cc/a154/pqEy.mp3', title: 'Heart Attack Speed', artist: 'horeki' },
                { url: 'https://c.termai.cc/a141/DmDwDM.mp3', title: 'Shadow In My Room', artist: 'horeki' },
                { url: 'https://c.termai.cc/a124/cgzfsM.mp3', title: 'Hero', artist: 'horeki' },
                { url: 'https://c.termai.cc/a171/K9NiGZ.mp3', title: 'Photograph', artist: 'horeki' },
                { url: 'https://c.termai.cc/a113/bDGR.mp3', title: 'Pop Is A Rockstar', artist: 'horeki' },
            ];

            let currentIndex = 0;
            let isPlaying = false;
            let isDragging = false;

            function loadTrack(index) {
                const track = tracks[index];
                if (!track) return;
                audio.src = track.url;
                audio.load();
                currentIndex = index;
                npTitle.textContent = track.title;
                npArtist.textContent = track.artist;
                statusText.textContent = 'memuat...';
                items.forEach((el, i) => {
                    el.classList.toggle('active', i === index);
                    const icon = el.querySelector('.pl-play i');
                    icon.className = (i === index && isPlaying) ? 'fas fa-pause' : 'fas fa-play';
                });
                progressFill.style.width = '0%';
                currentTimeLabel.textContent = '0:00';
                totalTimeLabel.textContent = '0:00';
                if (isPlaying) audio.play().catch(() => {});
            }

            function togglePlay() {
                if (!audio.src) { loadTrack(0); audio.play().catch(() => {}); return; }
                if (audio.paused) audio.play().catch(() => {});
                else audio.pause();
            }

            function updatePlayButton() {
                if (audio.paused) {
                    playIcon.className = 'fas fa-play';
                    isPlaying = false;
                    statusText.textContent = 'berhenti';
                    items.forEach((el, i) => { if (i === currentIndex) el.querySelector('.pl-play i').className = 'fas fa-play'; });
                } else {
                    playIcon.className = 'fas fa-pause';
                    isPlaying = true;
                    statusText.textContent = 'memutar';
                    items.forEach((el, i) => { if (i === currentIndex) el.querySelector('.pl-play i').className = 'fas fa-pause'; });
                }
            }

            function formatTime(sec) {
                if (isNaN(sec) || sec === Infinity || sec < 0) return '0:00';
                const m = Math.floor(sec / 60);
                const s = Math.floor(sec % 60);
                return m + ':' + (s < 10 ? '0' : '') + s;
            }

            function updateProgress() {
                if (isDragging) return;
                if (audio.duration && !isNaN(audio.duration)) {
                    const pct = (audio.currentTime / audio.duration) * 100;
                    progressFill.style.width = pct + '%';
                    currentTimeLabel.textContent = formatTime(audio.currentTime);
                    totalTimeLabel.textContent = formatTime(audio.duration);
                } else {
                    totalTimeLabel.textContent = '--:--';
                }
            }

            function setProgress(e) {
                const rect = progressBar.getBoundingClientRect();
                let x = (e.clientX - rect.left) / rect.width;
                x = Math.min(1, Math.max(0, x));
                if (audio.duration && !isNaN(audio.duration)) {
                    audio.currentTime = x * audio.duration;
                    progressFill.style.width = (x * 100) + '%';
                    currentTimeLabel.textContent = formatTime(audio.currentTime);
                }
            }

            playBtn.addEventListener('click', togglePlay);
            audio.addEventListener('play', updatePlayButton);
            audio.addEventListener('pause', updatePlayButton);
            audio.addEventListener('ended', () => {
                const next = (currentIndex + 1) % tracks.length;
                loadTrack(next);
                if (isPlaying) audio.play().catch(() => {});
                updatePlayButton();
            });
            audio.addEventListener('timeupdate', updateProgress);
            audio.addEventListener('loadedmetadata', () => {
                totalTimeLabel.textContent = formatTime(audio.duration);
                const el = durElements[currentIndex];
                if (el && audio.duration) el.textContent = formatTime(audio.duration);
                statusText.textContent = audio.paused ? 'siap' : 'memutar';
            });

            progressBar.addEventListener('mousedown', (e) => {
                isDragging = true;
                setProgress(e);
                document.addEventListener('mousemove', onDragMove);
                document.addEventListener('mouseup', onDragUp);
            });

            function onDragMove(e) { setProgress(e); }
            function onDragUp(e) {
                setProgress(e);
                isDragging = false;
                document.removeEventListener('mousemove', onDragMove);
                document.removeEventListener('mouseup', onDragUp);
            }

            items.forEach((item, index) => {
                item.addEventListener('click', () => {
                    if (currentIndex === index && !audio.paused) {
                        audio.pause();
                    } else {
                        loadTrack(index);
                        audio.play().catch(() => {});
                    }
                });
            });

            document.getElementById('prevBtn').addEventListener('click', () => {
                const prev = (currentIndex - 1 + tracks.length) % tracks.length;
                loadTrack(prev);
                if (isPlaying) audio.play().catch(() => {});
            });
            document.getElementById('nextBtn').addEventListener('click', () => {
                const next = (currentIndex + 1) % tracks.length;
                loadTrack(next);
                if (isPlaying) audio.play().catch(() => {});
            });

            document.addEventListener('keydown', (e) => {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
                if (e.code === 'Space') { e.preventDefault(); togglePlay(); }
            });

            // Inisialisasi
            loadTrack(0);

            // Preload durasi untuk semua lagu
            tracks.forEach((track, i) => {
                if (i === 0) return;
                const tmp = new Audio();
                tmp.preload = 'metadata';
                tmp.src = track.url;
                tmp.addEventListener('loadedmetadata', () => {
                    const dur = tmp.duration;
                    if (durElements[i] && !isNaN(dur)) durElements[i].textContent = formatTime(dur);
                    tmp.src = '';
                });
                tmp.addEventListener('error', () => {});
            });

            audio.addEventListener('error', () => {
                statusText.textContent = 'error';
                console.warn('Audio error:', audio.error);
            });
            console.log('🎵 room musik horeki v1.0 siap!');
        })();
    </script>
